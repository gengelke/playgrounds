SHELL := /usr/bin/env bash
.DEFAULT_GOAL := help

MAKEFILE_DIR := $(dir $(abspath $(lastword $(MAKEFILE_LIST))))
VAULT_DIR ?= $(abspath $(MAKEFILE_DIR)/../vault)
PORTS_FILE ?= $(abspath $(MAKEFILE_DIR)/../ports.env)
-include $(PORTS_FILE)
include $(MAKEFILE_DIR)/../scripts/lib/common.mk

MODE ?= docker
VAULT_ADDR ?= http://127.0.0.1:8200

GITEA_HTTP_PORT ?= 3000
GITEA_SSH_PORT ?= 2222
GITEA_DOMAIN ?= localhost
GITEA_ROOT_URL ?= http://localhost:$(GITEA_HTTP_PORT)/
GITEA_ADMIN_USER ?= admin
GITEA_ADMIN_PASSWORD ?= password
GITEA_ADMIN_EMAIL ?= admin@example.com
GITEA_USER ?= myuser
GITEA_USER_PASSWORD ?= password
GITEA_USER_EMAIL ?= myuser@example.com
GITEA_AUTO_ADD_EXAMPLE_WORKFLOW ?= true
GITEA_EXAMPLE_REPO ?= actions-example
GITEA_REMOVE_EXAMPLE_WORKFLOW_REPO ?= false
GITEA_AUTO_ADD_JENKINS_EXAMPLE ?= true
GITEA_JENKINS_EXAMPLE_REPO ?= jenkins-example
GITEA_AUTO_ADD_GENERATE_LIBRARY ?= true
GITEA_GENERATE_LIBRARY_REPO ?= generate-library
GITEA_SECRET_KEY ?=
GITEA_INTERNAL_TOKEN ?=
GITEA_JWT_SECRET ?=
RUNNER1_NAME ?= agent-runner-1
RUNNER2_NAME ?= agent-runner-2
RUNNER_LABELS_DOCKER ?= linux-amd64:docker://node:20-bookworm
RUNNER_LABELS_BARE ?= linux-amd64:host
GITEA_BIN ?= gitea
ACT_RUNNER_BIN ?= act_runner

export MODE
export GITEA_HTTP_PORT
export GITEA_SSH_PORT
export GITEA_DOMAIN
export GITEA_ROOT_URL
export GITEA_ADMIN_USER
export GITEA_ADMIN_PASSWORD
export GITEA_ADMIN_EMAIL
export GITEA_USER
export GITEA_USER_PASSWORD
export GITEA_USER_EMAIL
export GITEA_AUTO_ADD_EXAMPLE_WORKFLOW
export GITEA_EXAMPLE_REPO
export GITEA_REMOVE_EXAMPLE_WORKFLOW_REPO
export GITEA_AUTO_ADD_JENKINS_EXAMPLE
export GITEA_JENKINS_EXAMPLE_REPO
export GITEA_AUTO_ADD_GENERATE_LIBRARY
export GITEA_GENERATE_LIBRARY_REPO
export GITEA_SECRET_KEY
export GITEA_INTERNAL_TOKEN
export GITEA_JWT_SECRET
export RUNNER1_NAME
export RUNNER2_NAME
export RUNNER_LABELS_DOCKER
export RUNNER_LABELS_BARE
export GITEA_BIN
export ACT_RUNNER_BIN

.PHONY: up down restart logs status ps help ensure-vault clean distclean \
	docker-up docker-down bare-up bare-down docker-logs bare-logs docker-status bare-status

ensure-vault: check-mode
	@VAULT_ADDR="$(VAULT_ADDR)" VAULT_DIR="$(VAULT_DIR)" MODE="$(MODE)" \
		bash "$(MAKEFILE_DIR)/../scripts/lib/vault-check.sh"

docker-up: ensure-vault
	@$(MAKEFILE_DIR)scripts/up-docker.sh

docker-down:
	@$(MAKEFILE_DIR)scripts/down-docker.sh

docker-logs:
	@docker compose -f docker-compose.yml logs -f --tail=100 gitea runner1 runner2

docker-status:
	@docker compose -f docker-compose.yml ps

bare-up: ensure-vault
	@$(MAKEFILE_DIR)scripts/up-bare.sh

bare-down:
	@$(MAKEFILE_DIR)scripts/down-bare.sh

bare-logs:
	@$(MAKEFILE_DIR)scripts/logs-bare.sh

bare-status:
	@$(MAKEFILE_DIR)scripts/status-bare.sh

up: check-mode
	@$(MAKE) $(MODE)-up

down: check-mode
	@$(MAKE) $(MODE)-down

restart: down up

logs: check-mode
	@$(MAKE) $(MODE)-logs

status: check-mode
	@$(MAKE) $(MODE)-status

ps: status

help:
	@printf "%s\n" \
		"Usage:" \
		"  make up MODE=docker|bare" \
		"  make down MODE=docker|bare" \
		"  make logs MODE=docker|bare" \
		"  make status MODE=docker|bare" \
		"" \
		"Important variables (override as needed):" \
		"  GITEA_HTTP_PORT=$(GITEA_HTTP_PORT)" \
		"  GITEA_SSH_PORT=$(GITEA_SSH_PORT)" \
		"  GITEA_ROOT_URL=$(GITEA_ROOT_URL)" \
		"  GITEA_ADMIN_USER=$(GITEA_ADMIN_USER)" \
		"  GITEA_ADMIN_PASSWORD=$(GITEA_ADMIN_PASSWORD)" \
		"  GITEA_USER=$(GITEA_USER)" \
		"  GITEA_USER_PASSWORD=$(GITEA_USER_PASSWORD)" \
		"  GITEA_AUTO_ADD_EXAMPLE_WORKFLOW=$(GITEA_AUTO_ADD_EXAMPLE_WORKFLOW)" \
		"  GITEA_EXAMPLE_REPO=$(GITEA_EXAMPLE_REPO)" \
		"  GITEA_REMOVE_EXAMPLE_WORKFLOW_REPO=$(GITEA_REMOVE_EXAMPLE_WORKFLOW_REPO)" \
		"  GITEA_AUTO_ADD_JENKINS_EXAMPLE=$(GITEA_AUTO_ADD_JENKINS_EXAMPLE)" \
		"  GITEA_JENKINS_EXAMPLE_REPO=$(GITEA_JENKINS_EXAMPLE_REPO)" \
		"  GITEA_AUTO_ADD_GENERATE_LIBRARY=$(GITEA_AUTO_ADD_GENERATE_LIBRARY)" \
		"  GITEA_GENERATE_LIBRARY_REPO=$(GITEA_GENERATE_LIBRARY_REPO)" \
		"  RUNNER1_NAME=$(RUNNER1_NAME)" \
		"  RUNNER2_NAME=$(RUNNER2_NAME)" \
		"  RUNNER_LABELS_DOCKER=$(RUNNER_LABELS_DOCKER)" \
		"  RUNNER_LABELS_BARE=$(RUNNER_LABELS_BARE)"

clean:
	@$(MAKE) down MODE=docker >/dev/null 2>&1 || true
	@$(MAKE) down MODE=bare >/dev/null 2>&1 || true
	@rm -rf runtime

distclean: clean
	@rm -rf .gitea
